  "audit_report": {
    "opinion": {
      "opinion_type": "qualified",
      "opinion_summary": "Qualified opinion due to (1) revenue recognition of advances/undelivered sales and (2) inventory costing issues described in the basis for qualified opinion.",
      "audited_statements": [
        "Statement of financial position as at 07 July 2024",
        "Statement of profit or loss and other comprehensive income",
        "Statement of changes in equity",
        "Statement of cash flows",
        "Summary of significant accounting policies and other explanatory information"
      ],
      "financial_reporting_framework": "International Financial Reporting Standards (IFRSs)"
    },
    "basis_for_qualified_opinion": [
      {
        "issue": "Revenue recognition of advances and undelivered sales",
        "amount_etb": 10241573.0,
        "description": "Advance collections were treated as sales and undelivered sales were recorded against cost of sales; revenue was recognized without satisfying performance obligations.",
        "standard_referenced": "IFRS 15",
        "reported_effect": "Sales and cost of sales may be overstated; non-compliance with IFRS 15."
      },
      {
        "issue": "Inventory costing (absorption of direct and indirect production costs)",
        "description": "Direct and indirect costs (materials, labour and overhead) were not absorbed into inventory cost at year end; vaccines inventory was valued using opening standard costing.",
        "standard_referenced": "IAS 2",
        "reported_effect": "Inventory and cost of sales may not be fairly stated; non-compliance with IAS 2."
      }
    ],
