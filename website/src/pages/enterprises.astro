---
import Layout from "../layouts/Layout.astro";
import { getAllEnterprises, formatETB } from "../data/enterprises";
import { Zap, Plug, Wheat, Mail, HardHat, Pickaxe, Waves, ChevronRight, Home, ArrowRight } from "@lucide/astro";

const enterprises = getAllEnterprises();

const sectorIconMap: Record<string, any> = {
  zap: Zap,
  plug: Plug,
  wheat: Wheat,
  mail: Mail,
  bolt: Zap,
  "hard-hat": HardHat,
  pickaxe: Pickaxe,
  waves: Waves,
};

function getOpinionColor(opinion: string): string {
  if (opinion.toLowerCase().includes("unmodified")) return "text-eth-green";
  if (opinion.toLowerCase().includes("qualified")) return "text-eth-gold";
  if (opinion.toLowerCase().includes("adverse")) return "text-eth-red";
  return "text-eth-text-muted";
}

function getOpinionBg(opinion: string): string {
  if (opinion.toLowerCase().includes("unmodified"))
    return "bg-eth-green/10 border-eth-green/20";
  if (opinion.toLowerCase().includes("qualified"))
    return "bg-eth-gold-light border-eth-gold/20";
  if (opinion.toLowerCase().includes("adverse"))
    return "bg-red-50 border-red-200";
  return "bg-eth-surface border-eth-card-border";
}
---

<Layout title="Enterprises — audit.et">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-4">
    <nav class="flex items-center gap-1.5 text-sm mb-8">
      <a href="/" class="inline-flex items-center gap-1 text-eth-text-muted hover:text-eth-green transition-colors">
        <Home class="w-3.5 h-3.5" />
        Home
      </a>
      <ChevronRight class="w-3.5 h-3.5 text-eth-text-muted/50" />
      <span class="text-eth-text font-medium">Enterprises</span>
    </nav>

    <h1 class="font-display text-3xl sm:text-4xl text-eth-text mb-2">
      Enterprises
    </h1>
    <p class="text-eth-text-muted mb-10 max-w-2xl">
      Select an enterprise to view detailed financial analysis and audit
      reports from Ethiopia's state-owned enterprises.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
      {
        enterprises.map((enterprise) => {
          const hasData = enterprise.years.length > 0;
          const latest = enterprise.years.at(-1);
          const prev = enterprise.years.at(-2);
          const revTrend =
            latest?.revenue != null && prev?.revenue != null
              ? ((latest.revenue - prev.revenue) / Math.abs(prev.revenue)) *
                100
              : null;

          return hasData ? (
            <a
              href={`/enterprise/${enterprise.id}`}
              class="group bg-eth-card border border-eth-card-border rounded-xl p-6 hover:border-eth-green/40 hover:shadow-md transition-all duration-200"
            >
              {/* Header */}
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-eth-green/10 flex items-center justify-center">
                    {(() => {
                      const IconComponent = sectorIconMap[enterprise.sectorIcon] ?? Zap;
                      return <IconComponent class="w-5 h-5 text-eth-green" />;
                    })()}
                  </div>
                  <div>
                    <h3 class="font-semibold text-eth-text group-hover:text-eth-green transition-colors">
                      {enterprise.shortName}
                    </h3>
                    <p class="text-eth-text-muted text-xs">
                      {enterprise.sector}
                    </p>
                  </div>
                </div>
                {latest && (
                  <span
                    class={`text-xs px-2 py-0.5 rounded-full border ${getOpinionBg(latest.auditOpinion)} ${getOpinionColor(latest.auditOpinion)}`}
                  >
                    {latest.auditOpinion}
                  </span>
                )}
              </div>

              <p class="text-eth-text-dim text-sm mb-4 line-clamp-2">
                {enterprise.name}
              </p>

              {/* Revenue */}
              {latest?.revenue != null && (
                <div class="mb-3">
                  <p class="text-eth-text-muted text-xs mb-0.5">
                    Latest Revenue ({latest.year})
                  </p>
                  <div class="flex items-baseline gap-2">
                    <span class="font-mono text-lg text-eth-text font-semibold">
                      {formatETB(latest.revenue, true)}
                    </span>
                    {revTrend != null && (
                      <span
                        class={`text-xs font-mono ${revTrend >= 0 ? "text-eth-green" : "text-eth-red"}`}
                      >
                        {revTrend >= 0 ? "+" : ""}
                        {revTrend.toFixed(1)}%
                      </span>
                    )}
                  </div>
                </div>
              )}

              {/* Mini bar chart - revenue over years */}
              {enterprise.years.filter((y) => y.revenue != null).length >
                1 && (
                <div class="flex items-end gap-0.5 h-8 mt-2">
                  {(() => {
                    const revenueYears = enterprise.years.filter(
                      (y) => y.revenue != null,
                    );
                    const maxRev = Math.max(
                      ...revenueYears.map((y) => Math.abs(y.revenue!)),
                    );
                    return revenueYears.map((y) => {
                      const height =
                        maxRev > 0
                          ? (Math.abs(y.revenue!) / maxRev) * 100
                          : 0;
                      const isNeg = y.revenue! < 0;
                      return (
                        <div
                          class="flex-1 rounded-sm min-w-[4px] transition-all group-hover:opacity-100 opacity-60"
                          style={`height: ${Math.max(height, 4)}%; background: ${isNeg ? "#C0392B" : "#1b3b34"};`}
                          title={`${y.year}: ${formatETB(y.revenue!, true)}`}
                        />
                      );
                    });
                  })()}
                </div>
              )}

              {/* Footer */}
              <div class="flex items-center justify-between mt-4 pt-3 border-t border-eth-card-border">
                <span class="text-eth-text-muted text-xs">
                  {enterprise.years[0]?.year}–
                  {enterprise.years.at(-1)?.year} &middot;{" "}
                  {enterprise.years.length} years
                </span>
                <span class="text-eth-green text-xs group-hover:translate-x-0.5 transition-transform inline-flex items-center gap-1">
                  View details
                  <ArrowRight class="w-3 h-3" />
                </span>
              </div>
            </a>
          ) : (
            <div
              class="bg-eth-card border border-dashed border-eth-card-border rounded-xl p-6"
            >
              {/* Header */}
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-eth-surface flex items-center justify-center">
                    {(() => {
                      const IconComponent = sectorIconMap[enterprise.sectorIcon] ?? Zap;
                      return <IconComponent class="w-5 h-5 text-eth-text-muted" />;
                    })()}
                  </div>
                  <div>
                    <h3 class="font-semibold text-eth-text">
                      {enterprise.shortName}
                    </h3>
                    <p class="text-eth-text-muted text-xs">
                      {enterprise.sector}
                    </p>
                  </div>
                </div>
                <span class="text-xs px-2 py-0.5 rounded-full border border-eth-card-border bg-eth-surface text-eth-text-muted">
                  No data
                </span>
              </div>

              <p class="text-eth-text-dim text-sm mb-4 line-clamp-2">
                {enterprise.name}
              </p>

              {/* No data placeholder */}
              <div class="flex flex-col items-center justify-center py-6 rounded-lg bg-eth-surface/50">
                <p class="text-eth-text-muted text-sm">
                  No audit data available yet
                </p>
              </div>

              {/* Footer */}
              <div class="mt-4 pt-3 border-t border-eth-card-border">
                <span class="text-eth-text-muted text-xs">
                  Data coming soon
                </span>
              </div>
            </div>
          );
        })
      }
    </div>
  </section>
</Layout>
